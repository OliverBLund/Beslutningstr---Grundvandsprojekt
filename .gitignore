*.pdf

# -----------------------------------------------------------------------
# Image outputs (generated by the workflow)
# -----------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.svg

# -----------------------------------------------------------------------
# Python cache and compiled files
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo

# -----------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------
.venv/
venv/
env/

# -----------------------------------------------------------------------
# OS / editor noise
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
